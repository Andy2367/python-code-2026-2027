import time
import webbrowser

class SongNode:
    def __init__(self, title, artist, Link):
        self.title = title
        self.artist = artist
        self.link = Link
        self.prev = None
        self.next = None

class playlist:
    def __init__(self):
        self.head = None
        self.tail = None
        self.current = None
    def add_song(self,title, artist, Link):
        node = SongNode(title, artist, Link)
        if not self.head:
            self.head = self.tail = self.current = node
        else:
            node.prev = self.tail
            self.tail.next = node
            self.tail = node
    def show_current(self):
        if self.current:
            print(f"now playing {self.current.title} - {self.current.artist}")
            webbrowser.open (self.current.link)
    def next_track(self):
        if self.current and self.current.next:
            self.current = self.current.next
    def prev_track(self):
        if self.current and self.current.prev:
            self.current = self.current.prev

    def deleteNode(self, dele):
        
        # Base Case
        if self.head is None or dele is None:
            return 
        
        # If node to be deleted is head node
        if self.head == dele:
            self.head = dele.next

        # Change next only if node to be 
        # deleted is NOT the last node
        if dele.next is not None:
            dele.next.prev = dele.prev
    
        # Change prev only if node to be 
        # deleted is NOT the first node
        if dele.prev is not None:
            dele.prev.next = dele.next

